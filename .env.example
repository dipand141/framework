# ─────────────────────────────────────────────────────────────────────────────
# U-Ask QA Automation – Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ─── Target URL ──────────────────────────────────────────────────────────────
CHATBOT_URL=https://beta-ask.u.ae/en/uask

# ─── Browser ─────────────────────────────────────────────────────────────────
BROWSER=chrome                  # chrome | firefox | edge
HEADLESS=false                  # true for CI pipelines
IMPLICIT_WAIT=10                # seconds
EXPLICIT_WAIT=30                # seconds

# ─── Language ────────────────────────────────────────────────────────────────
# Which language suite to run:  en | ar | both
TEST_LANGUAGE=both

# ─── Mobile Emulation ────────────────────────────────────────────────────────
MOBILE_EMULATION=false
MOBILE_DEVICE=iPhone 12

# ─── AI Response Validation ──────────────────────────────────────────────────
# Cosine-similarity threshold below which a response is flagged as potentially
# hallucinated or off-topic. Range 0–1. Recommended: 0.60–0.80
SIMILARITY_THRESHOLD=0.65

# Sentence-transformer model (downloaded automatically on first run)
SENTENCE_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Optional – enable LLM-based deep validation (requires an OpenAI key)
OPENAI_API_KEY=

# ─── Screenshots ─────────────────────────────────────────────────────────────
SCREENSHOT_ON_FAILURE=true
SCREENSHOTS_DIR=reports/screenshots

# ─── Allure ──────────────────────────────────────────────────────────────────
ALLURE_RESULTS_DIR=reports/allure-results

# ─── Selenium Grid (optional for remote / CI execution) ──────────────────────
SELENIUM_GRID_URL=

# ─── Retry / Rate-limit ──────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY=2.0
# Pause between consecutive chatbot messages (seconds) to avoid rate-limiting
INTER_MESSAGE_DELAY=1.5

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
